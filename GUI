-- Target Part dropdown (superior)
TargetPartDropdown.MouseButton1Click:Connect(function()
    local parts = {"Head", "Torso", "HumanoidRootPart", "UpperTorso"}
    local current = 1
    for i, v in ipairs(parts) do
        if v == TargetPartDropdown.Text then
            current = i % #parts + 1
            break
        end
    end
    TargetPartDropdown.Text = parts[current]
    if Aimbot and Aimbot.SetLockPart then
        Aimbot.SetLockPart(parts[current])
    end
end)

