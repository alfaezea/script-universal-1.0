        if v == BottomTargetDropdown.Text then
            current = i % #parts + 1
            break
        end
    end
    BottomTargetDropdown.Text = parts[current]
end)

-- Priority dropdown
PriorityDropdown.MouseButton1Click:Connect(function()
    local priorities = {"Distance", "Health", "Crosshair"}
    local current = 1
    for i, v in ipairs(priorities) do
        if v == PriorityDropdown.Text then
            current = i % #priorities + 1
            break
        end
    end
    PriorityDropdown.Text = priorities[current]
end)

