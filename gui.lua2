-- ========== FUNÇÕES DE CRIAÇÃO DE ELEMENTOS ==========
local function CreateSection(parent, title, y)
    local section = Instance.new("TextLabel")
    section.Size = UDim2.new(1, -20, 0, 30)
    section.Position = UDim2.new(0, 10, 0, y)
    section.BackgroundTransparency = 1
    section.Text = "⚡ " .. title
    section.TextColor3 = Settings.Menu.Accent
    section.TextSize = 18
    section.TextXAlignment = Enum.TextXAlignment.Left
    section.Font = Enum.Font.GothamBold
    section.Parent = parent
    return y + 35
end

local function CreateToggle(parent, x, y, text, callback, default)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 300, 0, 35)
    frame.Position = UDim2.new(0, x, 0, y)
    frame.BackgroundTransparency = 1
    frame.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Settings.Menu.TextColor
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.Parent = frame
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 60, 0, 25)
    toggle.Position = UDim2.new(0, 210, 0.5, -12.5)
    toggle.BackgroundColor3 = default and Settings.Menu.Accent or Color3.fromRGB(60, 60, 70)
    toggle.BorderSizePixel = 0
    toggle.Text = default and "ON" or "OFF"
    toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggle.TextSize = 12
    toggle.Font = Enum.Font.GothamBold
    toggle.Parent = frame
    
    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 6)
    toggleCorner.Parent = toggle
    
    local state = default
    toggle.MouseButton1Click:Connect(function()
        state = not state
        toggle.BackgroundColor3 = state and Settings.Menu.Accent or Color3.fromRGB(60, 60, 70)
        toggle.Text = state and "ON" or "OFF"
        callback(state)
    end)
    
    return frame
end

local function CreateSlider(parent, x, y, text, min, max, default, callback, suffix)
    suffix = suffix or ""
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 300, 0, 50)
    frame.Position = UDim2.new(0, x, 0, y)
    frame.BackgroundTransparency = 1
    frame.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 0, 20)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Settings.Menu.TextColor
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.Parent = frame
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 70, 0, 20)
    valueLabel.Position = UDim2.new(0, 210, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(default) .. suffix
    valueLabel.TextColor3 = Settings.Menu.Accent
    valueLabel.TextSize = 14
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.Parent = frame
    
    local slider = Instance.new("Frame")
    slider.Size = UDim2.new(1, 0, 0, 20)
    slider.Position = UDim2.new(0, 0, 0, 25)
    slider.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    slider.BorderSizePixel = 0
    slider.Parent = frame
    
    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 6)
    sliderCorner.Parent = slider
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Settings.Menu.Accent
    fill.BorderSizePixel = 0
    fill.Parent = slider
    
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 6)
    fillCorner.Parent = fill
    
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 1, 0)
    button.BackgroundTransparency = 1
    button.Text = ""
    button.Parent = slider
    
    local dragging = false
    local currentValue = default
    
    button.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mousePos = UserInputService:GetMouseLocation().X
            local sliderPos = slider.AbsolutePosition.X
            local sliderSize = slider.AbsoluteSize.X
            local relative = math.clamp(mousePos - sliderPos, 0, sliderSize)
            local value = min + (relative / sliderSize) * (max - min)
            value = math.floor(value * 10) / 10
            
            fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
            valueLabel.Text = tostring(value) .. suffix
            currentValue = value
            callback(value)
        end
    end)
end

local function CreateDropdown(parent, x, y, text, options, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 300, 0, 45)
    frame.Position = UDim2.new(0, x, 0, y)
    frame.BackgroundTransparency = 1
    frame.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 0, 20)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Settings.Menu.TextColor
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.Parent = frame
    
    local dropdown = Instance.new("TextButton")
    dropdown.Size = UDim2.new(0, 120, 0, 25)
    dropdown.Position = UDim2.new(0, 160, 0, 0)
    dropdown.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    dropdown.BorderSizePixel = 0
    dropdown.Text = default
    dropdown.TextColor3 = Color3.fromRGB(255, 255, 255)
    dropdown.TextSize = 12
    dropdown.Font = Enum.Font.Gotham
    dropdown.Parent = frame
    
    local dropdownCorner = Instance.new("UICorner")
    dropdownCorner.CornerRadius = UDim.new(0, 6)
    dropdownCorner.Parent = dropdown
    
    local menu = Instance.new("Frame")
    menu.Size = UDim2.new(0, 120, 0, #options * 25)
    menu.Position = UDim2.new(0, 160, 0, 25)
    menu.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    menu.BorderSizePixel = 0
    menu.Visible = false
    menu.Parent = frame
    
    local menuCorner = Instance.new("UICorner")
    menuCorner.CornerRadius = UDim.new(0, 6)
    menuCorner.Parent = menu
    
    for i, opt in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 25)
        btn.Position = UDim2.new(0, 0, 0, (i-1)*25)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
        btn.BorderSizePixel = 0
        btn.Text = opt
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 12
        btn.Font = Enum.Font.Gotham
        btn.Parent = menu
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 4)
        btnCorner.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            dropdown.Text = opt
            menu.Visible = false
            callback(opt)
        end)
    end
    
    dropdown.MouseButton1Click:Connect(function()
        menu.Visible = not menu.Visible
    end)
end

local function CreateColorPicker(parent, x, y, text, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 300, 0, 35)
    frame.Position = UDim2.new(0, x, 0, y)
    frame.BackgroundTransparency = 1
    frame.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Settings.Menu.TextColor
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.Parent = frame
    
    local colorBtn = Instance.new("TextButton")
    colorBtn.Size = UDim2.new(0, 40, 0, 25)
    colorBtn.Position = UDim2.new(0, 220, 0.5, -12.5)
    colorBtn.BackgroundColor3 = default
    colorBtn.BorderSizePixel = 0
    colorBtn.Text = ""
    colorBtn.Parent = frame
    
    local colorCorner = Instance.new("UICorner")
    colorCorner.CornerRadius = UDim.new(0, 6)
    colorCorner.Parent = colorBtn
    
    local colors = {
        Color3.fromRGB(255, 100, 100),
        Color3.fromRGB(100, 255, 100),
        Color3.fromRGB(100, 100, 255),
        Color3.fromRGB(255, 255, 100),
        Color3.fromRGB(255, 100, 255),
        Color3.fromRGB(100, 255, 255),
        Color3.fromRGB(255, 255, 255),
        Settings.Menu.Accent,
    }
    
    local index = 1
    colorBtn.MouseButton1Click:Connect(function()
        index = index % #colors + 1
        colorBtn.BackgroundColor3 = colors[index]
        callback(colors[index])
    end)
end

-- ========== ATUALIZAR CONTEÚDO DAS ABAS ==========
function UpdateContent(tab)
    for _, child in ipairs(ContentContainer:GetChildren()) do
        child:Destroy()
    end
    
    local y = 20
    
    if tab == "Aimbot" and Aimbot then
        y = CreateSection(ContentContainer, "CONFIGURAÇÕES DO AIMBOT", y)
        
        CreateToggle(ContentContainer, 10, y, "Ativar Aimbot", function(v) Aimbot.Settings.Enabled = v end, Aimbot.Settings.Enabled)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Team Check", function(v) Aimbot.Settings.TeamCheck = v end, Aimbot.Settings.TeamCheck)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Wall Check", function(v) Aimbot.Settings.WallCheck = v end, Aimbot.Settings.WallCheck)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Alive Check", function(v) Aimbot.Settings.AliveCheck = v end, Aimbot.Settings.AliveCheck)
        y = y + 40
        
        CreateDropdown(ContentContainer, 10, y, "Parte do Corpo", 
            {"Head", "HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso"}, 
            Aimbot.Settings.LockPart, 
            function(v) Aimbot.Settings.LockPart = v end)
        y = y + 50
        
        CreateSlider(ContentContainer, 10, y, "Suavidade", 0.1, 1, Aimbot.Settings.Smoothness, function(v) Aimbot.Settings.Smoothness = v end, "")
        y = y + 55
        CreateSlider(ContentContainer, 10, y, "FOV", 30, 360, Aimbot.FOVSettings.Amount, function(v) Aimbot.FOVSettings.Amount = v end, "°")
        y = y + 55
        
    elseif tab == "ESP" and WallHack then
        y = CreateSection(ContentContainer, "CONFIGURAÇÕES DO ESP", y)
        
        CreateToggle(ContentContainer, 10, y, "Ativar ESP", function(v) WallHack.Settings.Enabled = v end, WallHack.Settings.Enabled)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Team Check", function(v) WallHack.Settings.TeamCheck = v end, WallHack.Settings.TeamCheck)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Alive Check", function(v) WallHack.Settings.AliveCheck = v end, WallHack.Settings.AliveCheck)
        y = y + 40
        
        CreateSection(ContentContainer, "ELEMENTOS VISUAIS", y)
        y = y + 35
        
        CreateToggle(ContentContainer, 10, y, "Mostrar Caixas", function(v) WallHack.Visuals.BoxSettings.Enabled = v end, WallHack.Visuals.BoxSettings.Enabled)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Mostrar Nomes", function(v) WallHack.Visuals.ESPSettings.DisplayName = v end, WallHack.Visuals.ESPSettings.DisplayName)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Mostrar Distância", function(v) WallHack.Visuals.ESPSettings.DisplayDistance = v end, WallHack.Visuals.ESPSettings.DisplayDistance)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Mostrar Vida", function(v) WallHack.Visuals.ESPSettings.DisplayHealth = v end, WallHack.Visuals.ESPSettings.DisplayHealth)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Mostrar Tracers", function(v) WallHack.Visuals.TracersSettings.Enabled = v end, WallHack.Visuals.TracersSettings.Enabled)
        y = y + 40
        
    elseif tab == "Crosshair" and WallHack and WallHack.Crosshair then
        y = CreateSection(ContentContainer, "CONFIGURAÇÕES DO CROSSHAIR", y)
        
        CreateToggle(ContentContainer, 10, y, "Ativar Crosshair", function(v) WallHack.Crosshair.Settings.Enabled = v end, WallHack.Crosshair.Settings.Enabled)
        y = y + 40
        CreateToggle(ContentContainer, 10, y, "Ponto Central", function(v) WallHack.Crosshair.Settings.CenterDot = v end, WallHack.Crosshair.Settings.CenterDot)
        y = y + 40
        
        CreateDropdown(ContentContainer, 10, y, "Posição", {"Mouse", "Center"}, 
            WallHack.Crosshair.Settings.Type == 1 and "Mouse" or "Center", 
            function(v) WallHack.Crosshair.Settings.Type = v == "Mouse" and 1 or 2 end)
        y = y + 50
        
        CreateSlider(ContentContainer, 10, y, "Tamanho", 8, 24, WallHack.Crosshair.Settings.Size, function(v) WallHack.Crosshair.Settings.Size = v end, "")
        y = y + 55
        CreateSlider(ContentContainer, 10, y, "Espessura", 1, 5, WallHack.Crosshair.Settings.Thickness, function(v) WallHack.Crosshair.Settings.Thickness = v end, "")
        y = y + 55
        CreateSlider(ContentContainer, 10, y, "Gap", 0, 20, WallHack.Crosshair.Settings.GapSize, function(v) WallHack.Crosshair.Settings.GapSize = v end, "")
        y = y + 55
        CreateSlider(ContentContainer, 10, y, "Rotação", -180, 180, WallHack.Crosshair.Settings.Rotation, function(v) WallHack.Crosshair.Settings.Rotation = v end, "°")
        y = y + 55
        
    elseif tab == "Fly" then
        y = CreateSection(ContentContainer, "SISTEMA DE VOO", y)
        
        CreateToggle(ContentContainer, 10, y, "Ativar Fly", function(v) Settings.Fly.Enabled = v; ToggleFly(v) end, Settings.Fly.Enabled)
        y = y + 40
        CreateSlider(ContentContainer, 10, y, "Velocidade", 10, 200, Settings.Fly.Speed, function(v) Settings.Fly.Speed = v end, "")
        y = y + 55
        
        local controls = Instance.new("TextLabel")
        controls.Size = UDim2.new(1, -20, 0, 80)
        controls.Position = UDim2.new(0, 10, 0, y)
        controls.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        controls.BackgroundTransparency = 0.5
        controls.BorderSizePixel = 0
        controls.Text = "🎮 CONTROLES:\n\nWASD  -  Movimento\nEspaço  -  Subir\nShift  -  Descer"
        controls.TextColor3 = Settings.Menu.TextColor
        controls.TextSize = 14
        controls.Font = Enum.Font.Gotham
        controls.TextWrapped = true
        controls.Parent = ContentContainer
        
        local controlsCorner = Instance.new("UICorner")
        controlsCorner.CornerRadius = UDim.new(0, 10)
        controlsCorner.Parent = controls
        
    elseif tab == "Hitbox" and extender then
        y = CreateSection(ContentContainer, "HITBOX EXTENDER", y)
        
        CreateToggle(ContentContainer, 10, y, "Ativar Hitbox", function(v) 
            Settings.Hitbox.Enabled = v
            if v then extender:Start() else extender:Stop() end
        end, Settings.Hitbox.Enabled)
        y = y + 40
        
        CreateDropdown(ContentContainer, 10, y, "Parte do Corpo", 
            {"Head", "HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso"}, 
            Settings.Hitbox.TargetLimb, 
            function(v) Settings.Hitbox.TargetLimb = v; extender:Set("TARGET_LIMB", v) end)
        y = y + 50
        
        CreateDropdown(ContentContainer, 10, y, "Tecla Atalho", 
            {"L", "K", "J", "H", "G", "F", "E", "Q"}, 
            Settings.Hitbox.ToggleKey, 
            function(v) Settings.Hitbox.ToggleKey = v; extender:Set("TOGGLE", v) end)
        y = y + 50
        
        CreateSlider(ContentContainer, 10, y, "Tamanho", 5, 30, Settings.Hitbox.Size, function(v) Settings.Hitbox.Size = v; extender:Set("LIMB_SIZE", v) end, "")
        y = y + 55
        CreateSlider(ContentContainer, 10, y, "Transparência", 0, 1, Settings.Hitbox.Transparency, function(v) Settings.Hitbox.Transparency = v; extender:Set("LIMB_TRANSPARENCY", v) end, "")
        y = y + 55
        
        CreateToggle(ContentContainer, 10, y, "Team Check", function(v) Settings.Hitbox.TeamCheck = v; extender:Set("TEAM_CHECK", v) end, Settings.Hitbox.TeamCheck)
        y = y + 40
        
        CreateSection(ContentContainer, "HIGHLIGHT", y)
        y = y + 35
        
        CreateToggle(ContentContainer, 10, y, "Usar Highlight", function(v) Settings.Hitbox.UseHighlight = v; extender:Set("USE_HIGHLIGHT", v) end, Settings.Hitbox.UseHighlight)
        y = y + 40
        
        CreateColorPicker(ContentContainer, 10, y, "Cor do Fill", Settings.Hitbox.HighlightColor, function(v) Settings.Hitbox.HighlightColor = v; extender:Set("HIGHLIGHT_FILL_COLOR", v) end)
        y = y + 40
        CreateSlider(ContentContainer, 10, y, "Transparência Fill", 0, 1, Settings.Hitbox.HighlightTransparency, function(v) Settings.Hitbox.HighlightTransparency = v; extender:Set("HIGHLIGHT_FILL_TRANSPARENCY", v) end, "")
        y = y + 55
    end
end

-- Inicializar primeira aba
UpdateContent("Aimbot")

-- Tecla P para abrir/fechar
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.P then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

print("✅ PREMIUM HUB CARREGADO COM SUCESSO!")
print("📌 Pressione P para abrir/fechar")
print("🎯 Módulos ativos:", Aimbot and "Aimbot" or "", WallHack and "ESP" or "", Hitbox and "Hitbox" or "")
