-- ========== FUNÇÃO SEGURA PARA CARREGAR MÓDULOS ==========
local function loadModule(url, moduleName)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and result and #result > 0 then
        local func, err = loadstring(result)
        if func then
            func()
            print("✅ " .. moduleName .. " carregado com sucesso!")
            return true
        else
            warn("❌ Erro no " .. moduleName .. ": " .. err)
            return false
        end
    else
        warn("❌ Falha ao baixar " .. moduleName)
        return false
    end
end

